# =========================================================
# ResearchMate Environment Variables Template
# =========================================================
# 1. Copy this file and rename the copy to ".env"
# 2. Never commit the real ".env" file to GitHub
# 3. Get your Gemini API key from: https://aistudio.google.com/app/apikey
# =========================================================

GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: change the Gemini model used for chat generation
# gemini-2.5-flash = cheaper/faster, good for a student project
# gemini-3.5-flash = Google's newest GA model (July 2026), stronger reasoning
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Optional: change the embedding model
# gemini-embedding-001 = stable, text-only, well supported everywhere
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional: where ChromaDB stores its persistent data
CHROMA_PERSIST_DIR=vectorstore/chroma_db
